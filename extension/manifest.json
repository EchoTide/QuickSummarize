{
  "manifest_version": 3,
  "name": "QuickSummarize",
  "version": "0.1.2",
  "description": "Transcript-first YouTube video summary and chat workspace",
  "permissions": ["storage", "activeTab", "sidePanel", "contextMenus"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["dist/content.js"]
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": ["https://www.youtube.com/*"],
      "js": ["dist/webpage-content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js", "sidepanel.html", "sidepanel.css", "dist/sidepanel.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
